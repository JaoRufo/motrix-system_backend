# Configuração do Servidor
PORT=3000

# Configuração do Banco de Dados PostgreSQL
DATABASE_URL=postgres://usuario:senha@localhost:5432/oficina

# Configuração JWT
JWT_SECRET=sua_chave_super_ultra_secreta_aqui_mude_em_producao
JWT_EXPIRES_IN=24h

# Configuração Bcrypt
BCRYPT_ROUNDS=10

# Ambiente
NODE_ENV=development
